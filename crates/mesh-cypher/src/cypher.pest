WHITESPACE = _{ " " | "\t" | "\r" | "\n" }

query = { SOI ~ statement ~ EOI }

statement = {
    create_index_stmt | drop_index_stmt | show_indexes_stmt |
    unwind_stmt | merge_stmt | create_stmt | match_stmt | return_only_stmt
}

// Bare `RETURN <expr> AS alias` with no producer clause — Neo4j's
// canonical health-probe form (`RETURN 1`). Reuses the existing
// `return_tail` rule so the projection / DISTINCT / ORDER BY /
// SKIP / LIMIT all behave identically to a clause-attached
// RETURN. Lowered by the planner to a single-element UNWIND so the
// executor's Project pipeline produces exactly one row.
return_only_stmt = { return_tail }

create_stmt = { kw_create ~ pattern_list ~ return_tail? }
merge_stmt  = { kw_merge ~ node_pattern ~ merge_action* ~ return_tail? }

// `ON CREATE SET ...` / `ON MATCH SET ...` clauses on a MERGE.
// Both are optional and may appear in any order; the action is
// distinguished by whether the embedded `kw_create` or `kw_match`
// fires, both of which are silent (`_{}`) keywords reused from
// the top-level statement grammar.
merge_action = { kw_on ~ (merge_on_create | merge_on_match) ~ kw_set ~ set_items }
merge_on_create = @{ ^"create" ~ !id_cont }
merge_on_match  = @{ ^"match" ~ !id_cont }

// Schema DDL for property indexes. Uses the modern Neo4j 4.x+ form
// (`CREATE INDEX FOR (n:Label) ON (n.prop)`) without the optional
// index name — Mesh identifies indexes by their (label, property)
// pair, which keeps DROP/SHOW behavior uniform across the executor
// and the storage layer. Parens on both sides are mandatory so the
// grammar unambiguously terminates.
create_index_stmt = { kw_create ~ kw_index ~ kw_for ~ "(" ~ index_target ~ ")" ~ kw_on ~ "(" ~ index_property ~ ")" }
drop_index_stmt   = { kw_drop ~ kw_index ~ kw_for ~ "(" ~ index_target ~ ")" ~ kw_on ~ "(" ~ index_property ~ ")" }
show_indexes_stmt = { kw_show ~ kw_indexes }

// `n:Label` — the variable is required by the grammar but discarded
// by the builder (the index is per-label, not per-variable).
index_target = { identifier ~ ":" ~ identifier }
// `n.prop` — same: variable is required to be syntactically valid
// Cypher but ignored semantically.
index_property = { identifier ~ "." ~ identifier }

unwind_stmt = {
    kw_unwind ~ expression ~ kw_as ~ identifier ~
    where_clause? ~
    return_tail
}

match_stmt = {
    kw_match ~ pattern_list ~
    where_clause? ~
    optional_match_clause* ~
    (with_tail ~ return_tail | return_tail | ((set_tail | delete_tail | create_tail) ~ return_tail?))
}

// `OPTIONAL MATCH <pattern> [WHERE ...]` — left-join semantics.
// Sits between the required MATCH and the RETURN / WITH / SET /
// DELETE tail. Multiple clauses chain. Restricted at plan time
// to single-hop patterns whose start node is already bound by a
// prior MATCH; richer forms land in a follow-up phase.
optional_match_clause = { kw_optional ~ kw_match ~ pattern_list ~ where_clause? }

// Intermediate projection / filter stage. Behaves like a
// `return_tail` with a WHERE slot, and is lowered to the same
// Project (or Aggregate) operator followed by the same
// Distinct / OrderBy / Skip / Limit chain, plus a Filter for
// the optional WHERE. Chained WITHs (`WITH ... WITH ... RETURN`)
// are intentionally not supported yet — the surrounding
// `match_stmt` only allows one `with_tail` before the final
// `return_tail`.
with_tail = {
    kw_with ~ kw_distinct? ~ return_items ~
    where_clause? ~
    order_by_clause? ~
    skip_clause? ~
    limit_clause?
}

pattern_list = { pattern ~ ("," ~ pattern)* }
create_tail = { kw_create ~ pattern_list }

where_clause = { kw_where ~ expression }
skip_clause = { kw_skip ~ integer }
limit_clause = { kw_limit ~ integer }

return_tail = {
    kw_return ~ kw_distinct? ~ return_items ~
    order_by_clause? ~
    skip_clause? ~
    limit_clause?
}

order_by_clause = { ^"order" ~ ^"by" ~ sort_items }
sort_items = { sort_item ~ ("," ~ sort_item)* }
sort_item = { expression ~ sort_dir? }
sort_dir = { kw_asc | kw_desc }

set_tail = { kw_set ~ set_items }
set_items = { set_item ~ ("," ~ set_item)* }
set_item = { set_label_item | set_prop_item | set_merge_item | set_replace_item }
set_label_item = { identifier ~ label_spec+ }
set_prop_item = { property_access ~ "=" ~ expression }
set_merge_item = { identifier ~ "+=" ~ properties }
set_replace_item = { identifier ~ "=" ~ properties }

delete_tail = { kw_detach? ~ kw_delete ~ delete_items }
delete_items = { identifier ~ ("," ~ identifier)* }

pattern = { node_pattern ~ hop* }
hop = { rel_pattern ~ node_pattern }

rel_pattern = { rel_right | rel_left | rel_both }
rel_right = { "-" ~ rel_detail? ~ "->" }
rel_left = { "<-" ~ rel_detail? ~ "-" }
rel_both = { "-" ~ rel_detail? ~ "-" }
rel_detail = { "[" ~ identifier? ~ rel_type_spec? ~ var_length? ~ "]" }
rel_type_spec = { ":" ~ identifier }
var_length = { "*" ~ var_length_range? }
var_length_range = { bounded_range | exact_range }
bounded_range = { range_min? ~ ".." ~ range_max? }
range_min = { nn_integer }
range_max = { nn_integer }
exact_range = { nn_integer }
nn_integer = @{ ASCII_DIGIT+ }

node_pattern = { "(" ~ identifier? ~ label_spec* ~ properties? ~ ")" }
label_spec = { ":" ~ identifier }
properties = { "{" ~ (property_entry ~ ("," ~ property_entry)*)? ~ "}" }
property_entry = { identifier ~ ":" ~ property_value }
// Node-pattern property values are deliberately narrower than full
// expressions: only literals or parameters are allowed. This statically
// rejects things like `{name: m.y}` (free row references in pattern
// properties) without needing a planner-side scope check.
property_value = { literal | parameter }

return_items = { return_item ~ ("," ~ return_item)* }
return_item = { expression ~ (kw_as ~ identifier)? }

expression = { or_expr }
or_expr = { and_expr ~ (kw_or ~ and_expr)* }
and_expr = { not_expr ~ (kw_and ~ not_expr)* }
not_expr = { (kw_not ~ not_expr) | comparison }
comparison = { primary ~ (null_predicate | (comparison_op ~ primary))? }

// Postfix `IS NULL` / `IS NOT NULL`. Ordered so `IS NOT NULL`
// is tried first — the `NOT` alternative is a proper prefix of
// the plain form so the grammar would otherwise eagerly match
// `IS NULL` and leave `NOT NULL` dangling.
null_predicate = { is_not_null_op | is_null_op }
is_not_null_op = @{ ^"is" ~ (" " | "\t" | "\r" | "\n")+ ~ ^"not" ~ (" " | "\t" | "\r" | "\n")+ ~ ^"null" ~ !id_cont }
is_null_op     = @{ ^"is" ~ (" " | "\t" | "\r" | "\n")+ ~ ^"null" ~ !id_cont }

comparison_op = {
    op_starts_with | op_ends_with | op_contains |
    op_neq | op_leq | op_geq | op_eq | op_lt | op_gt
}
op_eq = { "=" }
op_neq = { "<>" }
op_leq = { "<=" }
op_geq = { ">=" }
op_lt = { "<" }
op_gt = { ">" }
// Cypher's case-insensitive string operators. Multi-word, so
// the grammar matches each keyword separately with `!id_cont`
// to keep them from sticking to trailing identifier chars.
op_starts_with = @{ ^"starts" ~ (" " | "\t")+ ~ ^"with" ~ !id_cont }
op_ends_with   = @{ ^"ends" ~ (" " | "\t")+ ~ ^"with" ~ !id_cont }
op_contains    = @{ ^"contains" ~ !id_cont }

primary = {
    case_expr |
    list_comp |
    list_literal |
    parameter |
    literal |
    function_call |
    property_access |
    identifier |
    ("(" ~ expression ~ ")")
}

// Compound-atomic: keeps `identifier`'s atomic semantics for the name
// portion while disallowing whitespace between `$` and the name. Allows
// both named (`$name`) and positional (`$0`) parameters — Neo4j's Python
// driver emits the latter for positional kwargs.
parameter = ${ "$" ~ (identifier | nn_integer) }

case_expr = {
    kw_case ~ case_scrutinee? ~ when_branch+ ~ else_branch? ~ kw_end
}
case_scrutinee = { expression }
when_branch = { kw_when ~ expression ~ kw_then ~ expression }
else_branch = { kw_else ~ expression }

list_literal = { "[" ~ (expression ~ ("," ~ expression)*)? ~ "]" }
list_comp = {
    "[" ~ identifier ~ kw_in ~ expression ~
    list_comp_where? ~ list_comp_proj? ~ "]"
}
list_comp_where = { kw_where ~ expression }
list_comp_proj = { "|" ~ expression }

function_call = { identifier ~ "(" ~ fn_args? ~ ")" }
fn_args = { count_star | fn_arg_list }
count_star = { "*" }
fn_arg_list = { kw_distinct? ~ expression ~ ("," ~ expression)* }

property_access = { identifier ~ "." ~ identifier }

literal = { float | integer | string | boolean_lit | null_lit }
float = @{ "-"? ~ ASCII_DIGIT+ ~ "." ~ ASCII_DIGIT+ }
integer = @{ "-"? ~ ASCII_DIGIT+ }
string = ${ "\"" ~ string_dq ~ "\"" | "'" ~ string_sq ~ "'" }
string_dq = @{ (!"\"" ~ ANY)* }
string_sq = @{ (!"'" ~ ANY)* }
boolean_lit = @{ (^"true" | ^"false") ~ !id_cont }
null_lit = @{ ^"null" ~ !id_cont }

identifier = @{ !reserved ~ (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")* }
id_cont = _{ ASCII_ALPHANUMERIC | "_" }

reserved = @{
    (^"create" | ^"merge" | ^"match" | ^"where" | ^"return" | ^"skip" | ^"limit" |
     ^"as" | ^"or" | ^"and" | ^"not" | ^"true" | ^"false" | ^"null" |
     ^"set" | ^"delete" | ^"detach" |
     ^"distinct" | ^"order" | ^"by" | ^"asc" | ^"desc" |
     ^"case" | ^"when" | ^"then" | ^"else" | ^"unwind" |
     ^"index" | ^"indexes" | ^"drop" | ^"show" | ^"for" | ^"on" |
     ^"with" | ^"optional" | ^"contains")
    ~ !id_cont
}

kw_create = _{ ^"create" }
kw_merge  = _{ ^"merge" }
kw_match = _{ ^"match" }
kw_where = _{ ^"where" }
kw_return = _{ ^"return" }
kw_skip = _{ ^"skip" }
kw_limit = _{ ^"limit" }
kw_as = @{ ^"as" ~ !id_cont }
kw_or = @{ ^"or" ~ !id_cont }
kw_and = @{ ^"and" ~ !id_cont }
kw_not = @{ ^"not" ~ !id_cont }
kw_set = _{ ^"set" }
kw_delete = _{ ^"delete" }
kw_detach = @{ ^"detach" ~ !id_cont }
kw_order = _{ ^"order" }
kw_by = _{ ^"by" }
kw_asc = @{ ^"asc" ~ !id_cont }
kw_desc = @{ ^"desc" ~ !id_cont }
kw_distinct = @{ ^"distinct" ~ !id_cont }
kw_case = @{ ^"case" ~ !id_cont }
kw_when = @{ ^"when" ~ !id_cont }
kw_then = @{ ^"then" ~ !id_cont }
kw_else = @{ ^"else" ~ !id_cont }
kw_end = @{ ^"end" ~ !id_cont }
kw_in = @{ ^"in" ~ !id_cont }
kw_unwind = _{ ^"unwind" ~ !id_cont }
kw_index = @{ ^"index" ~ !id_cont }
kw_indexes = @{ ^"indexes" ~ !id_cont }
kw_drop = @{ ^"drop" ~ !id_cont }
kw_show = @{ ^"show" ~ !id_cont }
kw_for = @{ ^"for" ~ !id_cont }
kw_on = @{ ^"on" ~ !id_cont }
kw_with = @{ ^"with" ~ !id_cont }
kw_optional = @{ ^"optional" ~ !id_cont }
