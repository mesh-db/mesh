WHITESPACE = _{ " " | "\t" | "\r" | "\n" }
COMMENT = _{ "//" ~ (!"\n" ~ ANY)* }

query = { SOI ~ (kw_explain | kw_profile)? ~ query_body ~ EOI }

// Top-level query: either a standalone non-read statement (DDL,
// CREATE), or a read query optionally stitched with UNION / UNION
// ALL into a stream of same-shape branches. UNION branches must be
// read statements — DDL and CREATE-only statements don't produce
// unionable row streams and are rejected at parse time.
query_body = {
    create_constraint_stmt | drop_constraint_stmt | show_constraints_stmt |
    create_point_index_stmt | drop_point_index_stmt | show_point_indexes_stmt |
    create_index_stmt | drop_index_stmt | show_indexes_stmt |
    union_query |
    create_stmt
}

// A read query, possibly composed of multiple branches joined by
// UNION / UNION ALL. The grammar allows zero joiners (one branch →
// a plain read query) and the parser flattens same-kind chains.
// Mixing UNION and UNION ALL in the same chain is rejected at
// build time — Neo4j doesn't allow it and the set semantics would
// be ambiguous.
union_query = {
    read_stmt ~ (kw_union ~ kw_all? ~ read_stmt)*
}

// Read-query branches allowed inside a `union_query`. Mirrors the
// read-only subset of `statement` — MATCH/MERGE-initiated,
// UNWIND-initiated, and bare RETURN. A `match_stmt` whose terminal
// tail carries SET/DELETE/CREATE still passes here because the
// grammar doesn't distinguish — the planner enforces that UNION
// branches only carry read-producing terminals.
read_stmt = {
    unwind_stmt | match_stmt | return_only_stmt
}

// Bare `RETURN <expr> AS alias` with no producer clause — Neo4j's
// canonical health-probe form (`RETURN 1`). Reuses the existing
// `return_tail` rule so the projection / DISTINCT / ORDER BY /
// SKIP / LIMIT all behave identically to a clause-attached
// RETURN. Lowered by the planner to a single-element UNWIND so the
// executor's Project pipeline produces exactly one row.
return_only_stmt = { return_tail }

create_stmt = { kw_create ~ pattern_list ~ return_tail? }

// A single `MERGE (pattern) [ON CREATE SET ...] [ON MATCH SET
// ...]` clause. `pattern` covers both node-only
// (`MERGE (n:Label {k: v})`) and edge merges
// (`MERGE (a)-[:REL]->(b)`) — the planner dispatches on
// whether `hops` is empty. MERGE-initiated queries flow through
// `match_stmt`'s reading_clause chain like any other reading
// clause, so multiple MERGEs compose naturally.
merge_clause = { kw_merge ~ pattern ~ merge_action* }

// `ON CREATE SET ...` / `ON MATCH SET ...` clauses on a MERGE.
// Both are optional and may appear in any order; the action is
// distinguished by whether the embedded `kw_create` or `kw_match`
// fires, both of which are silent (`_{}`) keywords reused from
// the top-level statement grammar.
merge_action = { kw_on ~ (merge_on_create | merge_on_match) ~ kw_set ~ set_items }
merge_on_create = @{ ^"create" ~ !id_cont }
merge_on_match  = @{ ^"match" ~ !id_cont }

// Schema DDL for property indexes. Uses the modern Neo4j 4.x+ form
// without the optional index name — Mesh identifies indexes by
// their `(scope_target, property)` pair, which keeps DROP/SHOW
// behavior uniform across the executor and the storage layer.
// Supports both scope forms:
//   `CREATE INDEX FOR (n:Label) ON (n.prop)`
//   `CREATE INDEX FOR ()-[r:TYPE]-() ON (r.prop)`
// The relationship form is listed first in the alternation so
// PEG commits on the leading `()-`.
create_index_stmt = {
    kw_create ~ kw_index ~ kw_for ~
    (index_rel_source | index_node_source) ~
    kw_on ~ "(" ~ index_property ~ ("," ~ index_property)* ~ ")"
}
drop_index_stmt = {
    kw_drop ~ kw_index ~ kw_for ~
    (index_rel_source | index_node_source) ~
    kw_on ~ "(" ~ index_property ~ ("," ~ index_property)* ~ ")"
}
show_indexes_stmt = { kw_show ~ kw_indexes }

// Point / spatial index DDL. Single-property; both node scope
// `FOR (n:Label) ON (n.p)` and relationship scope
// `FOR ()-[r:TYPE]-() ON (r.p)` are accepted — the two variants
// use distinct storage CFs and separate registry vectors, so DROP
// disambiguates through the scope source.
create_point_index_stmt = {
    kw_create ~ kw_point ~ kw_index ~ kw_for ~
    (index_rel_source | index_node_source) ~
    kw_on ~ "(" ~ index_property ~ ")"
}
drop_point_index_stmt = {
    kw_drop ~ kw_point ~ kw_index ~ kw_for ~
    (index_rel_source | index_node_source) ~
    kw_on ~ "(" ~ index_property ~ ")"
}
show_point_indexes_stmt = { kw_show ~ kw_point ~ kw_indexes }

// Node source: `(var:Label)`. The variable is grammar-required but
// discarded by the builder — the index is per-label, not
// per-variable. Kept paren-wrapped so downstream parsing can tell
// a node-scoped target from the rel form by the leading token.
index_node_source = { "(" ~ index_target ~ ")" }

// Relationship source: `()-[var:TYPE]-()`. Direction is not
// significant for an index — edges of the type get indexed
// regardless of which endpoint you scanned from — so we accept
// the undirected form and both arrow shapes at the same
// priority, matching `constraint_rel_source`.
index_rel_source = {
    "(" ~ ")" ~ rel_edge ~ "[" ~ identifier ~ ":" ~ identifier ~ "]" ~ rel_edge ~ "(" ~ ")"
}

// `n:Label` — the variable is required by the grammar but discarded
// by the builder (the index is per-label, not per-variable).
index_target = { identifier ~ ":" ~ identifier }
// `n.prop` / `r.prop` — same: variable is required to be
// syntactically valid Cypher but ignored semantically.
index_property = { identifier ~ "." ~ identifier }

// Schema DDL for constraints. Neo4j 5.x form:
//   CREATE CONSTRAINT [name] [IF NOT EXISTS] FOR (n:Label)
//                     REQUIRE n.prop IS UNIQUE
//   CREATE CONSTRAINT [name] [IF NOT EXISTS] FOR (n:Label)
//                     REQUIRE n.prop IS NOT NULL
//   DROP CONSTRAINT name [IF EXISTS]
//   SHOW CONSTRAINTS
//
// v1 surface: single-label, single-property constraints, node scope
// only. Composite `IS NODE KEY` and relationship constraints land in a
// follow-up — see the Implementation Status section in CLAUDE.md.
create_constraint_stmt = {
    kw_create ~ kw_constraint ~
    constraint_name_opt? ~ if_not_exists? ~
    kw_for ~ (constraint_rel_source | constraint_node_source) ~
    kw_require ~ (constraint_property_list | constraint_property) ~
    constraint_requirement
}

// Node source: `(var:Label)`. The enclosing `create_constraint_stmt`
// accepts either this or the relationship source; alternation tries
// the relationship form first because its `()-[...]-()` prefix is
// unambiguous.
constraint_node_source = { "(" ~ constraint_target ~ ")" }

// Relationship source: `()-[var:TYPE]-()`. Direction is not
// significant for constraints — edges of the type are constrained
// regardless of which endpoint you scanned from — so we accept the
// undirected form and both arrow shapes at the same priority.
constraint_rel_source = {
    "(" ~ ")" ~ rel_edge ~ "[" ~ identifier ~ ":" ~ identifier ~ "]" ~ rel_edge ~ "(" ~ ")"
}
rel_edge = { "<-" | "->" | "-" }

// Parenthesized property list for composite constraints:
//   REQUIRE (n.a, n.b) IS NODE KEY
// The single-property form stays on `constraint_property` — the
// alternation in `create_constraint_stmt` tries the list form first
// so a leading `(` commits deterministically.
constraint_property_list = { "(" ~ constraint_property ~ ("," ~ constraint_property)* ~ ")" }

// Negative-lookahead guard: we only commit to parsing an identifier as
// the user-supplied name when the next token isn't `IF NOT EXISTS` or
// `FOR`. Without this peek, `CREATE CONSTRAINT IF NOT EXISTS FOR ...`
// would greedily take `IF` as the name and dead-end at the next token.
constraint_name_opt = { !if_not_exists ~ !kw_for ~ identifier }

drop_constraint_stmt = {
    kw_drop ~ kw_constraint ~ identifier ~ if_exists?
}

show_constraints_stmt = { kw_show ~ kw_constraints }

// `n:Label` / `n.prop` — same shape as the index DDL rules. The
// pattern variable is grammar-required but discarded by the builder.
constraint_target = { identifier ~ ":" ~ identifier }
constraint_property = { identifier ~ "." ~ identifier }

constraint_requirement = { req_unique | req_not_null | req_node_key | req_property_type }
// Both shapes are atomic so internal whitespace can't collapse into
// the `identifier` builder — a bare `IS` followed by an identifier
// wouldn't otherwise terminate. `ws_req` is required between each
// keyword to match Cypher's single-word-per-token convention.
req_unique = @{ ^"is" ~ ws_req ~ ^"unique" ~ !id_cont }
req_not_null = @{ ^"is" ~ ws_req ~ ^"not" ~ ws_req ~ ^"null" ~ !id_cont }
// `IS NODE KEY` — composite uniqueness + existence. Atomic so the
// two-word tail stays one token from the grammar's perspective.
req_node_key = @{ ^"is" ~ ws_req ~ ^"node" ~ ws_req ~ ^"key" ~ !id_cont }

// `IS :: <TYPE>` — property-type requirement. The `::` is a literal
// two-char token; whitespace around it is optional. `property_type_tag`
// is a separate non-atomic rule so the builder can pull the matched
// type name out as a distinct child pair.
req_property_type = { kw_is ~ "::" ~ property_type_tag }
kw_is = @{ ^"is" ~ !id_cont }
property_type_tag = @{
    (^"string" | ^"integer" | ^"float" | ^"boolean") ~ !id_cont
}

if_not_exists = @{ ^"if" ~ ws_req ~ ^"not" ~ ws_req ~ ^"exists" ~ !id_cont }
if_exists = @{ ^"if" ~ ws_req ~ ^"exists" ~ !id_cont }

// Whitespace marker used inside atomic rules — the top-level
// `WHITESPACE` silent rule doesn't fire inside `@{}`, so we spell
// the whitespace requirement out explicitly wherever an atomic
// phrase spans multiple keyword tokens.
ws_req = _{ (" " | "\t" | "\r" | "\n")+ }

unwind_stmt = {
    kw_unwind ~ expression ~ kw_as ~ identifier ~
    where_clause? ~
    return_tail
}

// A reading-clause-initiated query. Despite the name, this
// rule handles both MATCH- and MERGE-initiated statements —
// MERGE-initiated queries flow through here because
// `merge_clause` is a valid `reading_clause`, and there's no
// separate `merge_stmt` at the top level anymore. The
// terminal tail is optional: a bare `MERGE (n)` has no
// RETURN but is still valid (it's effectful).
match_stmt = {
    (reading_clause | mutation_clause)+ ~ terminal_tail?
}

// One reading stage. The parser enforces that the first
// `reading_clause` in a `match_stmt` is a `match_clause` — a
// query can't start with OPTIONAL MATCH or WITH without
// something to pull rows from first.
reading_clause = {
    match_clause | optional_match_clause | with_tail | merge_clause | unwind_clause | call_subquery | call_procedure | load_csv_clause
}

load_csv_clause = {
    kw_load ~ kw_csv ~ (kw_with ~ kw_headers)? ~ kw_from ~ expression ~ kw_as ~ identifier
}

call_subquery = { kw_call ~ "{" ~ union_query ~ "}" ~ in_transactions_suffix? }
// Optional Neo4j 5 batched-write suffix:
//   CALL { ... } IN TRANSACTIONS
//   CALL { ... } IN TRANSACTIONS OF 100 ROWS
//   CALL { ... } IN TRANSACTIONS ON ERROR { FAIL | CONTINUE | BREAK }
//   CALL { ... } IN TRANSACTIONS OF 100 ROWS ON ERROR CONTINUE
//   CALL { ... } IN TRANSACTIONS REPORT STATUS AS s
//   CALL { ... } IN TRANSACTIONS OF 100 ROWS ON ERROR CONTINUE REPORT STATUS AS s
// When present, the body runs in batches of `batch_size` input rows
// and each batch commits as an independent transaction. Default
// batch size when `OF n ROWS` is omitted is 1000 (matching Neo4j);
// default error mode is FAIL. REPORT STATUS replaces the body's
// emitted rows with one status-Map row per batch (bound to the
// supplied identifier).
in_transactions_suffix = {
    kw_in
    ~ kw_transactions
    ~ in_transactions_batch?
    ~ in_transactions_on_error?
    ~ in_transactions_report?
}
in_transactions_batch = { kw_of ~ nn_integer ~ kw_rows }
in_transactions_on_error = { kw_on ~ kw_error ~ on_error_mode }
on_error_mode = { kw_fail | kw_continue | kw_break }
in_transactions_report = { kw_report ~ kw_status ~ kw_as ~ identifier }
kw_transactions = @{ ^"transactions" ~ !id_cont }
kw_of = @{ ^"of" ~ !id_cont }
kw_rows = @{ ^"rows" ~ !id_cont }
kw_error = @{ ^"error" ~ !id_cont }
kw_fail = @{ ^"fail" ~ !id_cont }
kw_continue = @{ ^"continue" ~ !id_cont }
kw_break = @{ ^"break" ~ !id_cont }
kw_report = @{ ^"report" ~ !id_cont }
kw_status = @{ ^"status" ~ !id_cont }

// A procedure call, either standalone (`CALL ns.name[(args)] [YIELD ...]`)
// or appearing mid-query as a reading clause. The grammar doesn't
// distinguish between the two — the planner decides based on
// whether the call is the entire query body or sits inside a
// `match_stmt`.
//
// Ordering note: `call_subquery` (body `{`) is tried before this
// rule inside `reading_clause` so subquery-style calls aren't
// accidentally committed as procedure calls.
call_procedure = { kw_call ~ procedure_name ~ procedure_args? ~ yield_clause? }
// Procedure name segments are allowed to coincide with Cypher
// reserved words (e.g. `apoc.create.node`, `apoc.merge.node`) —
// the CALL context disambiguates them from clause keywords, so
// `procedure_name_segment` skips the `!reserved` guard that
// `identifier` enforces. Backticked names still go through.
procedure_name = { procedure_name_segment ~ ("." ~ procedure_name_segment)* }
procedure_name_segment = @{ backtick_id | (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")* }
procedure_args = { "(" ~ procedure_arg_list? ~ ")" }
procedure_arg_list = { expression ~ ("," ~ expression)* }
yield_clause = { kw_yield ~ (yield_star | yield_items) }
yield_star = { "*" }
yield_items = { yield_item ~ ("," ~ yield_item)* }
yield_item = { identifier ~ (kw_as ~ identifier)? }

// `UNWIND expression AS alias` as a mid-query reading clause —
// expands the current row stream by cross-joining each row with
// the elements of the list expression. Distinct from `unwind_stmt`,
// which requires a terminal `return_tail` and only works as a
// top-level producer. The clause form composes with MATCH / WITH
// / MERGE so queries like `MATCH (n) UNWIND n.tags AS t RETURN t`
// and `UNWIND $ids AS id MATCH (u {id: id}) RETURN u` lower
// through the same reading-clause loop as everything else.
unwind_clause = { kw_unwind ~ expression ~ kw_as ~ identifier }

// A single `MATCH pattern_list [WHERE expr]` — the producer
// form that scans the store for pattern matches. Extracted
// from the old inline `match_stmt` body so it can appear
// anywhere in the reading-clause sequence, not just at the
// start.
match_clause = {
    kw_match ~ pattern_list ~ where_clause?
}

// Terminal / writing tail. Either a pure RETURN, or a
// mutating clause (SET / DELETE / CREATE) optionally followed
// by a trailing RETURN. Always the last child of a
// `match_stmt`.
terminal_tail = {
    return_tail
    | (mutation_clause+ ~ return_tail?)
}
mutation_clause = { set_tail | delete_tail | create_tail | remove_tail | foreach_tail }

foreach_tail = {
    kw_foreach ~ "(" ~ identifier ~ kw_in ~ expression ~ "|" ~ foreach_body+ ~ ")"
}
foreach_body = { set_tail | remove_tail }

// `OPTIONAL MATCH <pattern> [WHERE ...]` — left-join semantics.
// A reading clause that extends the row stream with Null
// bindings when the optional pattern doesn't match. Restricted
// at plan time to single-hop patterns whose start node is
// already bound by an earlier clause.
optional_match_clause = { kw_optional ~ kw_match ~ pattern_list ~ where_clause? }

// Intermediate projection / filter stage. Behaves like a
// `return_tail` with a WHERE slot, and is lowered to the same
// Project (or Aggregate) operator followed by the same
// Distinct / OrderBy / Skip / Limit chain, plus a Filter for
// the optional WHERE. Chained WITHs (`WITH ... WITH ... RETURN`)
// and post-WITH reading clauses (`WITH ... MATCH ...`) work
// naturally because each `with_tail` is just one entry in
// the parent `reading_clause+` sequence.
with_tail = {
    kw_with ~ kw_distinct? ~ return_items ~
    where_clause? ~
    order_by_clause? ~
    skip_clause? ~
    limit_clause?
}

pattern_list = { pattern ~ ("," ~ pattern)* }
create_tail = { kw_create ~ pattern_list }

where_clause = { kw_where ~ expression }
skip_clause = { kw_skip ~ expression }
limit_clause = { kw_limit ~ expression }

return_tail = {
    kw_return ~ kw_distinct? ~ return_items ~
    order_by_clause? ~
    skip_clause? ~
    limit_clause?
}

order_by_clause = { ^"order" ~ ^"by" ~ sort_items }
sort_items = { sort_item ~ ("," ~ sort_item)* }
sort_item = { expression ~ sort_dir? }
sort_dir = { kw_asc | kw_desc }

set_tail = { kw_set ~ set_items }
set_items = { set_item ~ ("," ~ set_item)* }
set_item = { set_label_item | set_prop_item | set_merge_item | set_replace_item }
set_label_item = { identifier ~ label_spec+ }
// `SET x.k = v` normally — but Cypher also allows a parenthesized
// expression on the left (`SET (n).k = v`) so the LHS can be any
// `(expr).identifier` shape. We handle both forms: the bare
// `property_access` path is the fast case; the parenthesised one
// requires the expression to resolve to a node or edge at runtime.
set_prop_item = { (set_paren_lhs | property_access) ~ "=" ~ expression }
set_paren_lhs = { "(" ~ expression ~ ")" ~ "." ~ identifier }
// `SET x += <rhs>` / `SET x = <rhs>` where rhs is either a map
// literal (`{k: v, ...}`), a bound node/edge identifier (copies
// its properties — TCK Merge6/Merge7 scenario 4+6), or a
// parameter (a map-valued $param). Grammar-level alternation so
// the planner can distinguish without re-walking a generic
// expression tree.
set_merge_item = { identifier ~ "+=" ~ (properties | parameter | identifier) }
set_replace_item = { identifier ~ "=" ~ (properties | parameter | identifier) }

remove_tail = { kw_remove ~ remove_items }
remove_items = { remove_item ~ ("," ~ remove_item)* }
remove_item = { remove_label_item | remove_prop_item }
remove_label_item = { identifier ~ label_spec+ }
remove_prop_item = { property_access }

delete_tail = { kw_detach? ~ kw_delete ~ delete_items }
delete_items = { expression ~ ("," ~ expression)* }

// A pattern is a start node plus zero or more relationship+node
// hops, optionally prefixed with `<var> =` to bind the full
// traversal as a Path value. The named form is only valid in
// read contexts (MATCH / OPTIONAL MATCH) and is rejected by the
// planner for variable-length patterns — `VarLengthExpand`
// doesn't currently track intermediate nodes along the expanded
// walk, and a Path requires them.
//
// The pattern body can optionally be wrapped in
// `shortestPath(...)` or `allShortestPaths(...)` to request
// graph BFS instead of a full expand. Only one wrapping
// keyword is accepted per pattern; the planner rejects the
// wrapping form in CREATE contexts and rejects
// `allShortestPaths` (v1 only implements `shortestPath`).
pattern = { path_var_binding? ~ (shortest_path_form | raw_pattern) }
raw_pattern = { node_pattern ~ hop* }
shortest_path_form = {
    (kw_shortest_path | kw_all_shortest_paths) ~
    "(" ~ node_pattern ~ hop+ ~ ")"
}
path_var_binding = { identifier ~ "=" }
hop = { rel_pattern ~ node_pattern }

rel_pattern = { rel_both_arrows | rel_right | rel_left | rel_both }
rel_right = { "-" ~ rel_detail? ~ "->" ~ rel_quantifier? }
rel_left = { "<-" ~ rel_detail? ~ "-" ~ rel_quantifier? }
// `<-[r]->` / `<-->` — undirected-with-both-arrows shorthand. Neo4j
// treats this the same as `-[r]-` (unrestricted direction), so the
// builder lowers it to `Direction::Both`. Must sit before `rel_left`
// in the alternation because `rel_left` would otherwise commit on
// seeing `<-` and leave the trailing `->` dangling.
rel_both_arrows = { "<-" ~ rel_detail? ~ "->" ~ rel_quantifier? }
rel_both = { "-" ~ rel_detail? ~ "-" ~ rel_quantifier? }
// Neo4j 5 quantified-relationship shorthand: `+` is "one or more"
// (== `*1..`), `*` is "zero or more" (== `*0..`). Lives outside the
// bracketed rel_detail and, when present, lowers to the same
// `VarLength` that the inline `*min..max` form produces. The parser
// rejects combining a trailing quantifier with an inline var_length
// because they'd produce two conflicting hop ranges on the same rel.
//
// `brace_quantifier` handles the GQL-style `{n}` / `{n,m}` /
// `{n,}` / `{,m}` forms. Note: `{,m}` means min=0 (regex-style),
// differing from the inline `*..m` form which defaults min=1 —
// documented in `build_rel_pattern`.
rel_quantifier = { "+" | "*" | brace_quantifier }
brace_quantifier = { "{" ~ (brace_range | brace_exact) ~ "}" }
brace_range = { brace_min? ~ "," ~ brace_max? }
brace_min = { nn_integer }
brace_max = { nn_integer }
brace_exact = { nn_integer }
rel_detail = { "[" ~ identifier? ~ rel_type_spec? ~ var_length? ~ properties? ~ "]" }
rel_type_spec = { ":" ~ identifier ~ ("|" ~ ":"? ~ identifier)* }
var_length = { "*" ~ var_length_range? }
var_length_range = { bounded_range | exact_range }
bounded_range = { range_min? ~ ".." ~ range_max? }
range_min = { nn_integer }
range_max = { nn_integer }
exact_range = { nn_integer }
nn_integer = @{ ASCII_DIGIT+ }

node_pattern = { "(" ~ identifier? ~ label_spec* ~ properties? ~ ")" }
label_spec = { ":" ~ identifier }
properties = { "{" ~ (property_entry ~ ("," ~ property_entry)*)? ~ "}" }
property_entry = { map_key ~ ":" ~ property_value }
// Node-pattern property values are full expressions — the TCK uses
// in-scope bindings here (e.g. `UNWIND r AS i CREATE (n {var: i})`),
// so we can't restrict at the grammar level. Unbound identifiers
// fall out as a plan-time `UndefinedVariable` via the usual scope
// check on pattern property expressions.
property_value = { expression }

return_items = { return_star | (return_item ~ ("," ~ return_item)*) }
return_star = { "*" }
return_item = { expression ~ (kw_as ~ identifier)? }

expression = { or_expr }
or_expr = { xor_expr ~ (kw_or ~ xor_expr)* }
xor_expr = { and_expr ~ (kw_xor ~ and_expr)* }
and_expr = { not_expr ~ (kw_and ~ not_expr)* }
not_expr = { (kw_not ~ not_expr) | comparison }
// A comparison is one `compound` (an `add_expr` plus any trailing
// `IS NULL` / `IN ...` / label test) optionally followed by one or
// more `comparison_op compound` tails. Supporting a chain lets
// `1 < n.num < 3` parse Python-style (AST builder splits the chain
// into `1 < n.num AND n.num < 3`).
comparison = { compound ~ (comparison_op ~ compound)* }
compound = { add_expr ~ (null_predicate | in_predicate | label_predicate)? }
in_predicate = { kw_in ~ add_expr }
label_predicate = { label_spec+ }

// Arithmetic precedence levels. `add_expr` has `+` / `-`,
// below it `mul_expr` has `*` / `/` / `%`, and the lowest
// binding `unary_expr` lets a leading `-` negate a primary.
// Left-associative via pest's repetition: `a - b - c` parses
// as `((a - b) - c)` which matches standard arithmetic.
//
// Both arithmetic levels sit between `comparison` and
// `primary`, so a mixed expression like `a.age + 1 > 18`
// parses as `(a.age + 1) > 18` instead of trying to treat the
// comparison as a primary.
add_expr = { mul_expr ~ ((op_add | op_sub) ~ mul_expr)* }
mul_expr = { pow_expr ~ ((op_mul | op_div | op_mod) ~ pow_expr)* }
pow_expr = { unary_expr ~ (op_pow ~ unary_expr)* }
unary_expr = { (op_neg ~ unary_expr) | primary }

op_add = { "+" }
op_sub = { "-" }
op_mul = { "*" }
op_div = { "/" }
op_mod = { "%" }
op_pow = { "^" }
op_neg = { "-" }

// Postfix `IS NULL` / `IS NOT NULL`. Ordered so `IS NOT NULL`
// is tried first — the `NOT` alternative is a proper prefix of
// the plain form so the grammar would otherwise eagerly match
// `IS NULL` and leave `NOT NULL` dangling.
null_predicate = { is_not_null_op | is_null_op }
is_not_null_op = @{ ^"is" ~ (" " | "\t" | "\r" | "\n")+ ~ ^"not" ~ (" " | "\t" | "\r" | "\n")+ ~ ^"null" ~ !id_cont }
is_null_op     = @{ ^"is" ~ (" " | "\t" | "\r" | "\n")+ ~ ^"null" ~ !id_cont }

comparison_op = {
    op_starts_with | op_ends_with | op_contains |
    op_regex_match |
    op_neq | op_leq | op_geq | op_eq | op_lt | op_gt
}
op_eq = { "=" }
op_neq = { "<>" }
op_leq = { "<=" }
op_geq = { ">=" }
op_lt = { "<" }
op_gt = { ">" }
// Cypher's case-insensitive string operators. Multi-word, so
// the grammar matches each keyword separately with `!id_cont`
// to keep them from sticking to trailing identifier chars.
op_starts_with = @{ ^"starts" ~ (" " | "\t")+ ~ ^"with" ~ !id_cont }
op_ends_with   = @{ ^"ends" ~ (" " | "\t")+ ~ ^"with" ~ !id_cont }
op_contains    = @{ ^"contains" ~ !id_cont }
op_regex_match = { "=~" }

// Property-access postfix: after any base primary, zero or more
// `.identifier` suffixes chain property lookups. `x.name` resolves
// via `property_access` inside `base_primary` (backward compat);
// `startNode(r).name` and `(a).prop.sub` use the postfix chain.
primary = { base_primary ~ postfix_chain* }
postfix_chain = { property_chain | index_access }
property_chain = { "." ~ identifier }
index_access = { "[" ~ (slice_both | slice_from | slice_to | slice_all | expression) ~ "]" }
slice_both = { expression ~ ".." ~ expression }
slice_from = { expression ~ ".." }
slice_to   = { ".." ~ expression }
slice_all  = { ".." }

base_primary = {
    case_expr |
    reduce_expr |
    list_predicate |
    count_subquery |
    exists_subquery |
    collect_subquery |
    pattern_comprehension |
    list_comp |
    list_literal |
    map_literal |
    parameter |
    literal |
    function_call |
    pattern_predicate |
    property_access |
    identifier |
    ("(" ~ expression ~ ")")
}

// `EXISTS { MATCH pattern [WHERE expr] }` — Cypher 5 subquery
// existence form. A strict superset of `pattern_predicate` that
// adds a WHERE clause evaluated against the matched row's
// (outer + inner) bindings. v1 restricts the body to a single
// `MATCH` + optional `WHERE`; full sub-pipelines (WITH, nested
// MATCH, aggregation) are deferred. Multi-pattern comma lists
// inside the MATCH are also deferred — v1 takes exactly one
// pattern.
count_subquery = {
    kw_count ~ "{" ~ subquery_body ~ "}"
}

exists_subquery = {
    kw_exists ~ "{" ~ subquery_body ~ "}"
}

// `COLLECT { <read_stmt> }` — Cypher 5 subquery expression that
// evaluates the body and gathers the results into a list. The
// body must project exactly one return column; evaluation returns
// the column values in row order as a `Property::List`.
collect_subquery = {
    kw_collect ~ "{" ~ subquery_body ~ "}"
}

subquery_body = { read_stmt | bare_match_body | bare_pattern_body }
bare_match_body = { kw_match ~ pattern_list ~ where_clause? }
bare_pattern_body = { pattern_list ~ where_clause? }

// A `pattern` used as a boolean expression — `(a)-[:KNOWS]->(b)`
// in a WHERE clause. Distinct from the top-level `pattern` rule
// by requiring at least one `hop`: a zero-hop pattern `(a)` is
// indistinguishable from a parenthesized identifier, and the
// latter is what drivers actually write, so we let `(a)` fall
// through the alternation to `("(" ~ expression ~ ")")`.
//
// PEG ordered choice tries this rule before
// `("(" ~ expression ~ ")")`, so `(x)-[:R]->(y)` is committed as
// a pattern predicate and `(x + 1)` falls through to a
// parenthesized expression because `node_pattern`'s internal
// structure won't match `x + 1`.
pattern_predicate = { node_pattern ~ hop+ }

// `reduce(acc = init, x IN source | body)`. A left fold with its
// own binding scope — `acc` holds the running accumulator, `x`
// binds to each element in turn, and `body` computes the next
// accumulator value. Parsed as a dedicated primary (not a plain
// function_call) because the argument list uses `=` and `|`
// which aren't legal inside a normal `fn_arg_list`. Slotted
// above `function_call` in the `primary` alternation so the
// `reduce` keyword is consumed as the special form.
reduce_expr = {
    kw_reduce ~ "(" ~
    identifier ~ "=" ~ expression ~ "," ~
    identifier ~ kw_in ~ expression ~ "|" ~ expression ~
    ")"
}

list_predicate = {
    list_pred_name ~ "(" ~ identifier ~ kw_in ~ expression ~ kw_where ~ expression ~ ")"
}
list_pred_name = @{ (^"any" | ^"all" | ^"none" | ^"single") ~ !id_cont }

// Map literal: `{k1: e1, k2: e2, ...}`. Distinct from pattern
// property maps (`node_pattern`'s `properties` rule) which only
// accept literals + parameters — map literals in expression
// context take any expression on the value side and so can
// reference row variables, call functions, etc. Keys are plain
// identifiers; Neo4j also supports string-literal keys but the v1
// restriction matches what driver code actually emits.
map_literal = { "{" ~ (map_entry ~ ("," ~ map_entry)*)? ~ "}" }
map_entry = { map_key ~ ":" ~ expression }
// Map keys accept reserved words (e.g. {null: 1, set: 2})
map_key = @{ backtick_id | (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")* }

// Compound-atomic: keeps `identifier`'s atomic semantics for the name
// portion while disallowing whitespace between `$` and the name. Allows
// both named (`$name`) and positional (`$0`) parameters — Neo4j's Python
// driver emits the latter for positional kwargs.
parameter = ${ "$" ~ (identifier | nn_integer) }

case_expr = {
    kw_case ~ case_scrutinee? ~ when_branch+ ~ else_branch? ~ kw_end
}
case_scrutinee = { expression }
when_branch = { kw_when ~ expression ~ kw_then ~ expression }
else_branch = { kw_else ~ expression }

list_literal = { "[" ~ (expression ~ ("," ~ expression)*)? ~ "]" }
// Pattern comprehension: `[(n)-[:T]->(m) [WHERE pred] | proj]`.
// Requires at least one hop so the parser can cleanly
// distinguish it from a list literal containing a single
// parenthesised expression. Placed before `list_comp` /
// `list_literal` in the primary alternation so PEG ordered
// choice tries the pattern shape first.
pattern_comprehension = {
    "[" ~ (identifier ~ "=")? ~ node_pattern ~ hop+ ~ list_comp_where? ~ "|" ~ expression ~ "]"
}
list_comp = {
    "[" ~ identifier ~ kw_in ~ expression ~
    list_comp_where? ~ list_comp_proj? ~ "]"
}
list_comp_where = { kw_where ~ expression }
list_comp_proj = { "|" ~ expression }

function_call = { identifier ~ ("." ~ qualified_part)* ~ "(" ~ fn_args? ~ ")" }
// Namespace / function-name suffix after a `.`. Reserved words are
// fine here — the leading `.` disambiguates them from statement
// keywords, so `apoc.map.merge(...)` parses even though `MERGE`
// starts a top-level clause.
qualified_part = @{ backtick_id | (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")* }
fn_args = { count_star | fn_arg_list }
count_star = { "*" }
fn_arg_list = { kw_distinct? ~ expression ~ ("," ~ expression)* }

property_access = { identifier ~ "." ~ identifier }

literal = { float | integer | string | boolean_lit | null_lit }
float = @{ "-"? ~ (ASCII_DIGIT+ ~ "." ~ ASCII_DIGIT+ | "." ~ ASCII_DIGIT+) ~ (("e" | "E") ~ ("-" | "+")? ~ ASCII_DIGIT+)?
         | "-"? ~ ASCII_DIGIT+ ~ ("e" | "E") ~ ("-" | "+")? ~ ASCII_DIGIT+ }
integer = @{ "-"? ~ (hex_integer | octal_integer | ASCII_DIGIT+) }
hex_integer = _{ ("0x" | "0X") ~ ASCII_HEX_DIGIT+ }
octal_integer = _{ ("0o" | "0O") ~ ('0'..'7')+ }
string = ${ "\"" ~ string_dq ~ "\"" | "'" ~ string_sq ~ "'" }
string_dq = @{ ("\\" ~ ANY | (!"\"" ~ !"\\" ~ ANY))* }
string_sq = @{ ("\\" ~ ANY | (!"'" ~ !"\\" ~ ANY))* }
boolean_lit = @{ (^"true" | ^"false") ~ !id_cont }
null_lit = @{ ^"null" ~ !id_cont }

identifier = @{ backtick_id | plain_id }
plain_id = @{ !reserved ~ (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")* }
backtick_id = @{ "`" ~ (!"`" ~ ANY)+ ~ "`" }
id_cont = _{ ASCII_ALPHANUMERIC | "_" }

reserved = @{
    (^"create" | ^"merge" | ^"match" | ^"where" | ^"return" | ^"skip" | ^"limit" |
     ^"as" | ^"or" | ^"and" | ^"not" | ^"true" | ^"false" | ^"null" |
     ^"set" | ^"delete" | ^"detach" |
     ^"distinct" | ^"order" | ^"by" | ^"ascending" | ^"asc" | ^"descending" | ^"desc" |
     ^"case" | ^"when" | ^"then" | ^"else" | ^"unwind" |
     ^"index" | ^"indexes" | ^"drop" | ^"show" | ^"for" | ^"on" |
     ^"constraint" | ^"constraints" | ^"require" | ^"unique" |
     ^"with" | ^"optional" | ^"remove")
    ~ !id_cont
}

kw_create = _{ ^"create" }
kw_merge  = _{ ^"merge" }
kw_match = _{ ^"match" }
kw_where = _{ ^"where" }
kw_return = _{ ^"return" }
kw_skip = _{ ^"skip" }
kw_limit = _{ ^"limit" }
kw_as = @{ ^"as" ~ !id_cont }
kw_or = @{ ^"or" ~ !id_cont }
kw_and = @{ ^"and" ~ !id_cont }
kw_not = @{ ^"not" ~ !id_cont }
kw_xor = @{ ^"xor" ~ !id_cont }
kw_set = _{ ^"set" }
kw_delete = _{ ^"delete" }
kw_detach = @{ ^"detach" ~ !id_cont }
kw_order = _{ ^"order" }
kw_by = _{ ^"by" }
kw_asc = @{ (^"ascending" | ^"asc") ~ !id_cont }
kw_desc = @{ (^"descending" | ^"desc") ~ !id_cont }
kw_distinct = @{ ^"distinct" ~ !id_cont }
kw_case = @{ ^"case" ~ !id_cont }
kw_when = @{ ^"when" ~ !id_cont }
kw_then = @{ ^"then" ~ !id_cont }
kw_else = @{ ^"else" ~ !id_cont }
kw_end = @{ ^"end" ~ !id_cont }
kw_in = @{ ^"in" ~ !id_cont }
kw_unwind = @{ ^"unwind" ~ !id_cont }
kw_index = @{ ^"index" ~ !id_cont }
kw_indexes = @{ ^"indexes" ~ !id_cont }
kw_point = @{ ^"point" ~ !id_cont }
kw_constraint = @{ ^"constraint" ~ !id_cont }
kw_constraints = @{ ^"constraints" ~ !id_cont }
kw_require = @{ ^"require" ~ !id_cont }
kw_drop = @{ ^"drop" ~ !id_cont }
kw_show = @{ ^"show" ~ !id_cont }
kw_for = @{ ^"for" ~ !id_cont }
kw_on = @{ ^"on" ~ !id_cont }
kw_with = @{ ^"with" ~ !id_cont }
kw_optional = @{ ^"optional" ~ !id_cont }
kw_union = @{ ^"union" ~ !id_cont }
kw_all = @{ ^"all" ~ !id_cont }
kw_reduce = @{ ^"reduce" ~ !id_cont }
kw_exists = @{ ^"exists" ~ !id_cont }
kw_explain = @{ ^"explain" ~ !id_cont }
kw_profile = @{ ^"profile" ~ !id_cont }
kw_remove = _{ ^"remove" }
kw_count = @{ ^"count" ~ !id_cont }
kw_collect = @{ ^"collect" ~ !id_cont }
kw_call = _{ ^"call" }
kw_yield = @{ ^"yield" ~ !id_cont }
kw_foreach = _{ ^"foreach" }
kw_load = _{ ^"load" }
kw_csv = @{ ^"csv" ~ !id_cont }
kw_headers = @{ ^"headers" ~ !id_cont }
kw_from = _{ ^"from" }
kw_shortest_path = @{ ^"shortestPath" ~ !id_cont }
kw_all_shortest_paths = @{ ^"allShortestPaths" ~ !id_cont }
